# Upstream relay backend
RELAY_UPSTREAM_URL=http://127.0.0.1:62311
RELAY_UPSTREAM_ADMIN_PASSWORD=change-this-upstream-admin-password

# Public URLs
RELAY_PUBLIC_PORTAL_BASE_URL=https://relay.example.com
RELAY_PUBLIC_API_BASE_URL=https://api.example.com/v1
RELAY_PUBLIC_ADMIN_BASE_URL=https://admin.example.com

# Session and cookie
RELAY_SESSION_SECRET=replace-with-a-long-random-secret
RELAY_COOKIE_SECURE=true

# Snapshot retention
RELAY_SNAPSHOT_DIR=./snapshots
RELAY_SNAPSHOT_KEEP_LATEST=20

# Bootstrap local portal admin
RELAY_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
RELAY_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
RELAY_BOOTSTRAP_ADMIN_NAME=Relay Admin

# Optional: manage Sub2API entry from environment
# RELAY_SUB2API_BASE_URL=http://127.0.0.1:8080
# RELAY_SUB2API_ENABLED=true
# RELAY_SUB2API_PUBLIC_URL=http://127.0.0.1:8080
# RELAY_SUB2API_ADMIN_URL=http://127.0.0.1:8080/admin
# RELAY_SUB2API_API_BASE_URL=http://127.0.0.1:8080/v1
# RELAY_SUB2API_HEALTH_URL=http://127.0.0.1:8080/health
# RELAY_SUB2API_ADMIN_API_KEY=replace-with-sub2api-admin-api-key
# RELAY_SUB2API_DEFAULT_ALLOWED_GROUPS=1,2,3
# RELAY_SUB2API_DEFAULT_CONCURRENCY=0
# RELAY_SUB2API_INITIAL_BALANCE=0
# RELAY_SUB2API_EMBED_MODE=new_tab
# RELAY_SUB2API_LABEL=Sub2API
# RELAY_SUB2API_DESCRIPTION=Official subscription entry managed by Sub2API

# CAPTCHA solver service keys (optional)
# Set one of the following if you want CAPTCHA solving support
TWOCAPTCHA_API_KEY=replace-with-your-2captcha-api-key
ANTICAPTCHA_API_KEY=replace-with-your-anti-captcha-api-key

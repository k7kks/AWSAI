[Unit]
Description=Kiro Relay Upstream
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__SERVICE_USER__
Group=__SERVICE_USER__
WorkingDirectory=__STATE_ROOT__/upstream
ExecStart=__APP_ROOT__/upstream/claude-server -data-dir __STATE_ROOT__/upstream -port 62311 -no-browser
Restart=on-failure
RestartSec=5
LimitNOFILE=65535
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=__STATE_ROOT__/upstream

[Install]
WantedBy=multi-user.target

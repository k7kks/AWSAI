RELAY_UPSTREAM_URL=http://127.0.0.1:62311
RELAY_UPSTREAM_ADMIN_PASSWORD=change-this-upstream-admin-password

RELAY_PUBLIC_PORTAL_BASE_URL=https://relay.example.com
RELAY_PUBLIC_API_BASE_URL=https://relay.example.com/v1
RELAY_PUBLIC_ADMIN_BASE_URL=https://relay.example.com/admin

RELAY_COOKIE_SECURE=true
RELAY_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
RELAY_BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
RELAY_BOOTSTRAP_ADMIN_NAME=Relay Admin

# Optional: manage Sub2API from the relay process
# RELAY_SUB2API_BASE_URL=http://127.0.0.1:8080
# RELAY_SUB2API_ENABLED=true
# RELAY_SUB2API_ADMIN_API_KEY=replace-with-sub2api-admin-api-key
